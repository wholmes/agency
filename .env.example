# Postgres (both required — see prisma/schema.prisma)
# Local: POSTGRES_PRISMA_URL can match DATABASE_URL if you use a single connection string.
# Production: use Neon’s pooled connection for POSTGRES_PRISMA_URL and direct for DATABASE_URL (see Neon/Vercel dashboard).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dbname?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/dbname?sslmode=require"

# Sync from Vercel (recommended once linked):
#   vercel env pull .env.local

# Admin UI at /admin — password must be at least 8 characters
ADMIN_PASSWORD="change-me-to-a-long-secret"

# Optional: separate signing key for the admin session cookie (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET="another-long-secret"
