# Copy to `.env.local` and fill in values (or `vercel env pull .env.local`).
# Never commit real secrets to git.

# --- Admin / app ---
# Canonical site URL for sitemap.xml, robots.txt sitemap line, and previews (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://brandmeetscode.com"

ADMIN_PASSWORD="*******************"
# ADMIN_SESSION_SECRET="*******************"
CONTACT_FROM_DOMAIN="onboarding@resend.dev"
CONTACT_TO_EMAIL="noreply@example.com"
RESEND_API_KEY="re_************************"

# --- Prisma: Neon (production / preview) OR local Docker (see docker-compose.yml) ---
#
# Neon (Vercel pull): use pooled string for POSTGRES_PRISMA_URL, direct (no -pooler) for DATABASE_URL.
# Strip channel_binding in app code if present; or remove from Vercel env.
#
# Local dev without Neon: start Postgres first — `npm run db:up` — then set BOTH to the same local URL.
# Example local (matches docker-compose in this repo):
#   postgresql://agency:agency@127.0.0.1:5432/agency?sslmode=disable

POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@YOUR_HOST/neondb?sslmode=require&pgbouncer=true"
DATABASE_URL="postgresql://USER:PASSWORD@YOUR_DIRECT_HOST/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@YOUR_DIRECT_HOST/neondb?sslmode=require"
POSTGRES_URL="postgresql://USER:PASSWORD@YOUR_POOLER_HOST/neondb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@YOUR_DIRECT_HOST/neondb?sslmode=require"

NEON_PROJECT_ID="your-neon-project-id"
PGDATABASE="neondb"
PGHOST="YOUR_POOLER_HOST"
PGHOST_UNPOOLED="YOUR_DIRECT_HOST"
PGPASSWORD="*******************"
PGUSER="neondb_owner"
POSTGRES_DATABASE="neondb"
POSTGRES_HOST="YOUR_POOLER_HOST"
POSTGRES_PASSWORD="*******************"
POSTGRES_USER="neondb_owner"

# ScreenshotOne / AWS (fill from your vault)
SCREENSHOTONE_ACCESS_KEY="****************"
SCREENSHOTONE_SECRET_KEY="****************"
AWS_ACCESS_KEY_ID="*************************"
AWS_SECRET_ACCESS_KEY="**************************************"
AWS_REGION="us-east-2"
AWS_S3_BUCKET="your-bucket-name"
