// BrandMeetsCode — content database (PostgreSQL via Vercel / Prisma Postgres)
//
// Env vars required:
//   DATABASE_URL        — postgresql://... (direct URL for local dev and migrations)
//
// When using Prisma Postgres Accelerate in production, add:
//   DATABASE_URL        — prisma+postgres://... (Accelerate URL, used at runtime)
//   DIRECT_DATABASE_URL — postgresql://...      (direct URL, used for migrations & seeding)
// and restore the `directUrl` line below + withAccelerate() in src/lib/prisma.ts.
//
// To provision: vercel integration add prisma  OR  npx prisma init --db
// Then pull:    vercel env pull .env.local
// Then migrate: npx prisma migrate dev --name init
// Then seed:    npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String  @id
  title        String
  category     String
  proofFit     String
  year         String
  result       String
  resultDetail String
  problem      String
  approach     String
  outcome      String
  color        String
  accent       String
  services     String
  sortOrder    Int     @default(0)
  published    Boolean @default(true)
}

model Capability {
  id         Int     @id @default(autoincrement())
  sortOrder  Int     @default(0)
  title      String
  descriptor String
  detail     String
  tags       String  @default("")
  showTags   Boolean @default(true)
  iconSvg    String  @default("")
  published  Boolean @default(true)
}

model SiteSettings {
  id                    Int     @id @default(1)
  contactEmail          String
  availabilityAvailable Boolean @default(true)
  availabilityLabel     String
  availabilityNextOpen  String?
  navHideOnScroll       Boolean @default(false)
}

model SocialStat {
  id        Int    @id @default(autoincrement())
  value     String
  label     String
  sortOrder Int    @default(0)
}

model SocialClient {
  id        Int    @id @default(autoincrement())
  name      String
  context   String
  sortOrder Int    @default(0)
}

model FeaturedTestimonial {
  id             Int    @id @default(1)
  quote          String
  authorName     String
  authorTitle    String
  authorInitials String
  starCount      Int    @default(5)
}

model ServiceOffering {
  id                 Int     @id @default(autoincrement())
  slug               String  @unique
  iconKey            String
  sortOrder          Int
  number             String?
  title              String
  subtitle           String?
  descriptionHome    String
  outcomesHome       String
  descriptionListing String
  outcomesListing    String
  href               String
  showOnHomepage     Boolean @default(true)
}

model ContinuityBlock {
  id        Int    @id @default(autoincrement())
  sortOrder Int
  title     String
  body      String
}

model LighthouseGuarantee {
  id    Int    @id @default(1)
  title String
  body  String
}

model HomeHero {
  id                  Int    @id @default(1)
  overline            String
  headlineLine1       String
  headlineLine2Italic String
  headlineLine3       String
  body                String
  primaryCtaLabel     String
  primaryCtaHref      String
  secondaryCtaLabel   String
  secondaryCtaHref    String
  /// Optional GA4 UTM params appended to primary CTA href at render time (do not put utm_* in href).
  primaryUtmSource    String?
  primaryUtmMedium    String?
  primaryUtmCampaign  String?
  primaryUtmContent   String?
  primaryUtmTerm      String?
  /// Optional GA4 UTM params appended to secondary CTA href at render time.
  secondaryUtmSource   String?
  secondaryUtmMedium   String?
  secondaryUtmCampaign String?
  secondaryUtmContent  String?
  secondaryUtmTerm     String?
}

model WorkPageHero {
  id                  Int    @id @default(1)
  overline            String
  headlineLine1       String
  headlineLine2Italic String
  body                String
}

model ServicesPageHero {
  id       Int    @id @default(1)
