}

/// /about — values section header
model AboutValuesSectionHeader {
  id       Int    @id @default(1)
  overline String
  heading  String
}

/// /contact — page copy (email address comes from SiteSettings)
model ContactPageCopy {
  id                   Int    @id @default(1)
  metaTitle            String
  metaDescription      String
  overline             String
  heroLineBeforeEm     String
  heroEmphasis         String
  heroLineAfterEm      String
  introParagraph       String
  whatHappensHeading   String
  nextSteps            String
  altRoutesHeading     String
  emailCardTitle       String
  calendarCardTitle    String
  calendarCardSubtitle String
  calendlyUrl          String
  calendlyUtmSource    String?
  calendlyUtmMedium    String?
  calendlyUtmCampaign  String?
  calendlyUtmContent   String?
  calendlyUtmTerm      String?
}

/// Labels for case study template (problem / approach / result / nav)
model CaseStudyUiLabels {
  id                     Int    @id @default(1)
  backToWorkLabel        String
  backToCaseStudiesLabel String
  problemSectionLabel    String
  approachSectionLabel   String
  outcomeSectionLabel    String
  similarProjectCtaLabel String
}

/// Contact form labels, options, and messages (JSON)
model ContactFormConfig {
  id         Int    @id @default(1)
  configJson String
}

/// /industries index — hero copy, card link label, SEO
model IndustriesHub {
  id              Int    @id @default(1)
  metaTitle       String
  metaDescription String
  overline        String
  headline        String
  introBody       String
  cardCtaLabel    String
}

/// Vertical / industry pages (e.g. /industries/startups)
model IndustryPage {
  slug                  String @id
  sortOrder             Int    @default(0)
  listTitle             String
  listBlurb             String
  metaTitle             String
  metaDescription       String
  heroOverline          String
  heroTitle             String
  heroBody              String
  introTitle            String
  introBody             String
  focusTitle            String
  focusBullets          String
  differentiatorTitle   String
  differentiatorBody    String
  ctaLabel              String
  ctaHref               String
}

/// Global SEO defaults and analytics script IDs
model SeoSettings {
  id                 Int     @id @default(1)
  /// Default <title> for the homepage and fallback for pages without their own title
  siteTitle          String  @default("BrandMeetsCode — Premium Web Development Agency")
  /// printf-style title template — %s is replaced with the page title
  titleTemplate      String  @default("%s | BrandMeetsCode")
  /// Default meta description (used when a page doesn't override it)
  metaDescription    String  @default("BrandMeetsCode builds premium websites where brand strategy meets technical execution.")
  /// Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Leave blank to disable.
  googleAnalyticsId  String  @default("")
  /// GA4 Measurement Protocol API Secret — used for server-side event tracking.
  /// Generate in GA4: Admin → Data Streams → stream → Measurement Protocol → API Secrets.
  googleAnalyticsApiSecret String @default("")
  /// Google Tag Manager Container ID (GTM-XXXXXXX). Leave blank to disable.
  googleTagManagerId String  @default("")
  /// When true, adds <meta name="robots" content="noindex,nofollow"> sitewide.
  /// Useful for staging / pre-launch environments.
  noIndex            Boolean @default(false)
}

/// Global nav + footer link columns (JSON)
model SiteChrome {
  id         Int    @id @default(1)
  configJson String
}

/// Email / notification settings for the contact form
/// The RESEND_API_KEY must still be set as an environment variable — it is never stored here.
model EmailSettings {
  id              Int     @id @default(1)
  /// Address that receives new inquiry notifications
  notifyEmail     String
  /// Human-readable sender name shown in email clients (e.g. "BrandMeetsCode")
  fromName        String  @default("BrandMeetsCode")
  /// Verified sending address in Resend (e.g. noreply@brandmeetscode.com)
  /// Use "onboarding@resend.dev" until your domain is verified
  fromAddress     String  @default("onboarding@resend.dev")
  /// Send an automated reply to the person who submitted the form
  autoReplyEnabled Boolean @default(true)
  /// Subject line for the auto-reply
  autoReplySubject String  @default("Got your message — I'll be in touch shortly")
  /// Opening line of the auto-reply ({{name}} is replaced)
  autoReplyOpening String  @default("Thanks for reaching out — I've received your message and will get back to you within 1–2 business days.")
}
