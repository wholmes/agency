{
  "name": "agency",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:seed": "dotenv -e .env -e .env.local -- prisma db seed",
    "db:migrate": "dotenv -e .env -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env -e .env.local -- prisma migrate deploy",
    "db:resolve-applied": "dotenv -e .env -e .env.local -- prisma migrate resolve --applied",
    "db:studio": "dotenv -e .env -e .env.local -- prisma studio",
    "screenshot:one": "dotenv -e .env -e .env.local -- tsx scripts/screenshot-one.mts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@prisma/client": "5.22.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/marked": "^5.0.2",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lenis": "^1.3.23",
    "marked": "^18.0.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
